# ============================================================
# PAKISTAN LEGAL AI AGENT - BACKEND ENVIRONMENT VARIABLES
# ============================================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pakistan_legal_ai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pakistan_legal_ai
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude AI (legacy — not currently used, ai.service.js runs on Gemini)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Google Gemini (FREE tier, no credit card) — powers ai.service.js
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (used ONLY for text-embedding-3-small — powers the local law
# library / RAG search in legalRetrievalService.js + embeddingService.js).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50mb
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,tiff,docx,doc
ENCRYPTION_KEY=your_32_char_encryption_key_here

# OCR
OCR_PROVIDER=tesseract
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng+urd

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Pakistan Legal AI <noreply@legalpk.ai>

# Redis (for sessions / rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,https://legalpk.ai
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@legalpk.ai
ADMIN_SECRET_KEY=your_admin_secret_for_seeding

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
